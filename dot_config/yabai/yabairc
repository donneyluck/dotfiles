#!/bin/bash

# ============================================
# Yabai config — based on i3 + Komorebi setup
# ============================================

# --- Global ---
yabai -m config layout                       bsp
yabai -m config top_padding                  32
yabai -m config bottom_padding               10
yabai -m config left_padding                 10
yabai -m config right_padding                10
yabai -m config window_gap                   10
yabai -m config window_shadow                float
yabai -m config window_opacity               on
yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity         1.0
yabai -m config normal_window_opacity         0.95
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 off
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

# --- Labels (spaces) ---
yabai -m space 1 --label term
yabai -m space 2 --label code
yabai -m space 3 --label web
yabai -m space 4 --label chat
yabai -m space 5 --label file
yabai -m space 6 --label tool
yabai -m space 7 --label obsidian
yabai -m space 8 --label media
yabai -m space 9 --label sunflower

# --- Rules ---
# Floating apps (manage=off)
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Installer$" manage=off
yabai -m rule --add app="^KeePassXC$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Preview$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^ zoom.us$" manage=off
yabai -m rule --add app="^FaceTime$" manage=off

# Space assignments (by numeric index, matching labels above)
# term=1, code=2, web=3, chat=4, file=5, tool=6, obsidian=7, media=8, sunflower=9
yabai -m rule --add app="^Alacritty$" space=1
yabai -m rule --add app="^kitty$" space=1
yabai -m rule --add app="^WezTerm$" space=1
yabai -m rule --add app="^Ghostty$" space=1
yabai -m rule --add app="^Code$" space=2
yabai -m rule --add app="^Code - Insiders$" space=2
yabai -m rule --add app="^Cursor$" space=2
yabai -m rule --add app="^Google Chrome$" space=3
yabai -m rule --add app="^Safari$" space=3
yabai -m rule --add app="^Arc$" space=3
yabai -m rule --add app="^Brave$" space=3
yabai -m rule --add app="^WeChat$" space=4
yabai -m rule --add app="^Lark$" space=4
yabai -m rule --add app="^Feishu$" space=4
yabai -m rule --add app="^Telegram$" space=4
yabai -m rule --add app="^Finder$" space=5
yabai -m rule --add app="^Clash Verge$" space=6
yabai -m rule --add app="^Obsidian$" space=7
yabai -m rule --add app="^VLC$" space=8
yabai -m rule --add app="^IINA$" space=8
yabai -m rule --add app="^Sunlogin" space=8
yabai -m rule --add app="^向日葵$" space=8

# --- Signals (tell sketchybar when things change) ---
yabai -m signal --add event=space_changed action="bash $HOME/.config/sketchybar/plugins/workspaces.sh" label="space_change"
yabai -m signal --add event=window_focused action="sketchybar --trigger window_focused" label="window_focused"
