#!/bin/bash

# ============================================
# Yabai config — based on i3 + Komorebi setup
# ============================================

# --- Global ---
yabai -m config layout                       bsp
yabai -m config top_padding                  10
yabai -m config bottom_padding               10
yabai -m config left_padding                 10
yabai -m config right_padding                10
yabai -m config window_gap                   10
yabai -m config window_shadow                float
yabai -m config window_opacity               on
yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity         1.0
yabai -m config normal_window_opacity         0.95
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 off
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

# --- Labels (spaces) ---
yabai -m space 1 --label term
yabai -m space 2 --label code
yabai -m space 3 --label web
yabai -m space 4 --label chat
yabai -m space 5 --label file
yabai -m space 6 --label tool
yabai -m space 7 --label obsidian
yabai -m space 8 --label media
yabai -m space 9 --label sunflower

# --- Rules ---
# Floating apps
yabai -m rule --add app="^System Preferences$"
yabai -m rule --add app="^System Settings$"
yabai -m rule --add app="^Installer$"
yabai -m rule --add app="^KeePassXC$"
yabai -m rule --add app="^Calculator$"
yabai -m rule --add app="^QuickTime Player$"
yabai -m rule --add app="^Preview$"
yabai -m rule --add app="^Activity Monitor$"
yabai -m rule --add app="^ zoom.us$"
yabai -m rule --add app="^FaceTime$"

# Space assignments
yabai -m rule --add app="^Alacritty$" space=term
yabai -m rule --add app="^kitty$" space=term
yabai -m rule --add app="^WezTerm$" space=term
yabai -m rule --add app="^Code$" space=code
yabai -m rule --add app="^Code - Insiders$" space=code
yabai -m rule --add app="^Cursor$" space=code
yabai -m rule --add app="^Ghostty$" space=term
yabai -m rule --add app="^Google Chrome$" space=web
yabai -m rule --add app="^Safari$" space=web
yabai -m rule --add app="^Arc$" space=web
yabai -m rule --add app="^Brave$" space=web
yabai -m rule --add app="^WeChat$" space=chat
yabai -m rule --add app="^Lark$" space=chat
yabai -m rule --add app="^Feishu$" space=chat
yabai -m rule --add app="^Telegram$" space=chat
yabai -m rule --add app="^Finder$" space=file
yabai -m rule --add app="^Obsidian$" space=obsidian
yabai -m rule --add app="^VLC$" space=media
yabai -m rule --add app="^IINA$" space=media

# --- Signals (optional, for borders/effects) ---
# yabai -m signal --add event=window_focused action="..."
