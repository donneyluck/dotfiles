#!/bin/bash
FONT="FiraCode Nerd Font:Bold:13.0"

sketchybar --bar height=28 position=top color=0xff1e1e2e \
                 padding_left=6 padding_right=6 \
                 font_smoothing=on

# ── Workspaces (text-only highlight) ──
for i in $(seq 1 9); do
  sketchybar --add item ws_$i left \
             --set ws_$i drawing=on \
                         icon.drawing=off \
                         label.color=0xff585b70 \
                         label.font="$FONT" \
                         label.padding_left=4 \
                         label.padding_right=4 \
                         click_script="yabai -m space --focus $i" \
                         script="bash $HOME/.config/sketchybar/plugins/workspaces.sh" \
                         update_freq=0
done

sketchybar --subscribe workspaces space_changed window_focused

# ── Window Title ──────────────────────────────────────────
sketchybar --add item window_title left \
           --set window_title drawing=on \
                           icon.drawing=off \
                           label.color=0xffa6adc8 \
                           label.max_chars=60 \
                           label.font="$FONT"

# ── CPU ───────────────────────────────────────────────────
sketchybar --add item cpu right \
           --set cpu drawing=on \
                       icon= \
                       icon.color=0xfff9e2af \
                       icon.padding_left=4 \
                       icon.font="$FONT" \
                       label.color=0xffffffff \
                       label.padding_right=8 \
                       label.font="$FONT"

# ── Network ───────────────────────────────────────────────
sketchybar --add item network right \
           --set network drawing=on \
                         icon= \
                         icon.color=0xff94e2d5 \
                         icon.padding_left=4 \
                         icon.font="$FONT" \
                         label.color=0xffffffff \
                         label.padding_right=8 \
                         label.font="$FONT"

# ── Clock ─────────────────────────────────────────────────
sketchybar --add item clock right \
           --set clock drawing=on \
                        icon= \
                        icon.color=0xfff5c2e7 \
                        icon.font="$FONT" \
                        label.color=0xffffffff \
                        label.padding_right=6 \
                        label.font="$FONT"